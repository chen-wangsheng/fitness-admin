<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.admin.user.mapper.AdminUserMapper">

    <select id="selectByUsername" resultType="com.fitness.admin.user.entity.AdminUser">
        SELECT * FROM admin_user WHERE username = #{username} AND deleted = 0 LIMIT 1
    </select>

</mapper>
