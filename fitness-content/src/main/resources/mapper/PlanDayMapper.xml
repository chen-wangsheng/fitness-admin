<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.admin.content.mapper.PlanDayMapper">

    <select id="selectByPlanId" resultType="com.fitness.admin.content.entity.PlanDay">
        SELECT * FROM plan_day WHERE plan_id = #{planId} ORDER BY week_number, day_of_week
    </select>

</mapper>
